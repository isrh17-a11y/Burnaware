datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Persona {
  STUDENT
  PROFESSIONAL
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  username       String              @unique
  persona        Persona             @default(STUDENT) // New field
  assessments    BurnoutAssessment[] // One-to-many relation
  journalEntries JournalEntry[] // One-to-many relation

  // Existing fields mapped over
  hashedPassword String?
  fullName       String?
  points         Int     @default(0)
  level          Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BurnoutAssessment {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  exhaustionScore      Float
  cynicismScore        Float
  professionalEfficacy Float
  phq4Score            Float?
  createdAt            DateTime @default(now())
}

model JournalEntry {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  emotionTag      String
  triggerCategory String
  content         String // Encrypted text application-side
  createdAt       DateTime @default(now())
}
